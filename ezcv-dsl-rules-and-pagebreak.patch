@@ -0,0 +1,15 @@
+import fs from 'fs';
+import path from 'path';
+
+/**
+ * Loads a prompt text file from /prompts.
+ * Falls back to an empty string if the file is missing.
+ */
+export function loadPromptText(filename) {
+  try {
+    const p = path.join(process.cwd(), 'prompts', filename);
+    return fs.readFileSync(p, 'utf8');
+  } catch (e) {
+    return '';
+  }
+}
